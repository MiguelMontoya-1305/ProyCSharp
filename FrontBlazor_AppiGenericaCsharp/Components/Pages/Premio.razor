@page "/premio"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Premio</PageTitle>

<div class="container mt-4">
    <h3>Premio</h3>
    <p class="lead">Gestión de premios asociados a programas académicos.</p>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Premio</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Premio" : "Nuevo Premio")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Descripción</label>
                        <input class="form-control" @bind="campoDescripcion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" class="form-control" @bind="campoFecha" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Entidad otorgante</label>
                        <input class="form-control" @bind="campoEntidadOtorgante" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">País</label>
                        <input class="form-control" @bind="campoPais" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoPrograma">
                            <option value="0">Seleccione un programa</option>
                            @foreach (var prog in programas)
                            {
                                <option value="@Convert.ToInt32(prog["id"])">@prog["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th>Entidad otorgante</th>
                    <th>País</th>
                    <th>Programa</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["descripcion"]</td>
                        <td>@reg["fecha"]</td>
                        <td>@reg["entidad_otorgante"]</td>
                        <td>@reg["pais"]</td>
                        <td>@ObtenerNombrePrograma(reg["programa"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla premio.</div>
    }
</div>

@code {
    // ───────── VARIABLES DE ESTADO ─────────
    // Lista de premios obtenidos desde la API
    private List<Dictionary<string, object?>> registros = new();
    // Lista de programas para relacionar el premio con un programa académico
    private List<Dictionary<string, object?>> programas = new();
    // Controla si se muestra el spinner de carga
    private bool cargando = true;
    // Controla si se muestra el formulario de creación/edición
    private bool mostrarFormulario = false;
    // Indica si estamos editando un registro existente
    private bool editando = false;
    // Mensaje de alerta para el usuario
    private string mensaje = string.Empty;
    // Indica si la última operación fue exitosa
    private bool exito = false;

    // Campos del formulario
    private string campoId = string.Empty;
    private string campoNombre = string.Empty;
    private string campoDescripcion = string.Empty;
    private DateTime? campoFecha = DateTime.Today;
    private string campoEntidadOtorgante = string.Empty;
    private string campoPais = string.Empty;
    private int campoPrograma = 0;

    // ───────── CICLO DE VIDA ─────────
    // Se ejecuta al inicializar el componente y carga los programas y premios
    protected override async Task OnInitializedAsync()
    {
        await CargarProgramas();
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("premio");
        cargando = false;
    }

    private async Task CargarProgramas()
    {
        programas = await Api.ListarAsync("programa");
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = string.Empty;
        campoNombre = string.Empty;
        campoDescripcion = string.Empty;
        campoFecha = DateTime.Today;
        campoEntidadOtorgante = string.Empty;
        campoPais = string.Empty;
        campoPrograma = 0;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? string.Empty;
        campoNombre = reg["nombre"]?.ToString() ?? string.Empty;
        campoDescripcion = reg["descripcion"]?.ToString() ?? string.Empty;
        campoFecha = reg["fecha"] is DateTime dt ? dt : DateTime.Today;
        campoEntidadOtorgante = reg["entidad_otorgante"]?.ToString() ?? string.Empty;
        campoPais = reg["pais"]?.ToString() ?? string.Empty;
        campoPrograma = int.TryParse(reg["programa"]?.ToString(), out var prog) ? prog : 0;
        mostrarFormulario = true;
        mensaje = string.Empty;
        await CargarProgramas();
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["nombre"] = campoNombre,
            ["descripcion"] = campoDescripcion,
            ["fecha"] = campoFecha?.ToString("yyyy-MM-dd"),
            ["entidad_otorgante"] = campoEntidadOtorgante,
            ["pais"] = campoPais,
            ["programa"] = campoPrograma
        };

        if (editando)
        {
            datos.Remove("id");
            var resultado = await Api.ActualizarAsync("premio", "id", campoId, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("premio", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var id = reg["id"]?.ToString() ?? string.Empty;
        var resultado = await Api.EliminarAsync("premio", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            await CargarRegistros();
        }
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }

    private string ObtenerNombrePrograma(string? id)
    {
        if (string.IsNullOrEmpty(id))
            return string.Empty;

        var prog = programas.FirstOrDefault(p => p["id"]?.ToString() == id);
        return prog?["nombre"]?.ToString() ?? id;
    }
}
