@page "/registro_calificado"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Registro Calificado</PageTitle>

<div class="container mt-4">
    <h3>Registro Calificado</h3>
    <p class="lead">Gestión de registros calificados de programas.</p>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Registro</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Registro" : "Nuevo Registro")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Código</label>
                        <input class="form-control" @bind="campoCodigo" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Créditos</label>
                        <input type="number" class="form-control" @bind="campoCantCreditos" min="0" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Horas acompañadas</label>
                        <input type="number" class="form-control" @bind="campoHoraAcom" min="0" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Horas independientes</label>
                        <input type="number" class="form-control" @bind="campoHoraInd" min="0" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Metodología</label>
                        <input class="form-control" @bind="campoMetodologia" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha inicio</label>
                        <input type="date" class="form-control" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha fin</label>
                        <input type="date" class="form-control" @bind="campoFechaFin" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Duración años</label>
                        <input type="number" class="form-control" @bind="campoDuracionAnios" min="0" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Duración semestres</label>
                        <input type="number" class="form-control" @bind="campoDuracionSemestres" min="0" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo titulación</label>
                        <input class="form-control" @bind="campoTipoTitulacion" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoPrograma">
                            <option value="0">Seleccione un programa</option>
                            @foreach (var prog in programas)
                            {
                                <option value="@Convert.ToInt32(prog["id"])">@prog["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Créditos</th>
                    <th>H. Acom</th>
                    <th>H. Ind</th>
                    <th>Metodología</th>
                    <th>Programa</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["codigo"]</td>
                        <td>@reg["cant_creditos"]</td>
                        <td>@reg["hora_acom"]</td>
                        <td>@reg["hora_ind"]</td>
                        <td>@reg["metodologia"]</td>
                        <td>@ObtenerNombrePrograma(reg["programa"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla registro_calificado.</div>
    }
</div>

@code {
    // ───────── VARIABLES DE ESTADO ─────────
    // Lista de registros calificados obtenidos desde la API
    private List<Dictionary<string, object?>> registros = new();
    // Lista de programas para relacionar cada registro calificado con su programa
    private List<Dictionary<string, object?>> programas = new();
    // Controla si se muestra el spinner de carga
    private bool cargando = true;
    // Controla si se muestra el formulario de creación/edición
    private bool mostrarFormulario = false;
    // Indica si estamos editando un registro existente
    private bool editando = false;
    // Mensaje de alerta para el usuario
    private string mensaje = string.Empty;
    // Indica si la última operación fue exitosa
    private bool exito = false;

    // Campos del formulario
    private string campoCodigo = string.Empty;
    private int campoCantCreditos = 0;
    private int campoHoraAcom = 0;
    private int campoHoraInd = 0;
    private string campoMetodologia = string.Empty;
    private DateTime? campoFechaInicio = DateTime.Today;
    private DateTime? campoFechaFin = null;
    private int campoDuracionAnios = 0;
    private int campoDuracionSemestres = 0;
    private string campoTipoTitulacion = string.Empty;
    private int campoPrograma = 0;

    // ───────── CICLO DE VIDA ─────────
    // Se ejecuta al inicializar el componente y carga registros y programas
    protected override async Task OnInitializedAsync()
    {
        await CargarProgramas();
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("registro_calificado");
        cargando = false;
    }

    private async Task CargarProgramas()
    {
        programas = await Api.ListarAsync("programa");
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoCodigo = string.Empty;
        campoCantCreditos = 0;
        campoHoraAcom = 0;
        campoHoraInd = 0;
        campoMetodologia = string.Empty;
        campoFechaInicio = DateTime.Today;
        campoFechaFin = null;
        campoDuracionAnios = 0;
        campoDuracionSemestres = 0;
        campoTipoTitulacion = string.Empty;
        campoPrograma = 0;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoCodigo = reg["codigo"]?.ToString() ?? string.Empty;
        campoCantCreditos = int.TryParse(reg["cant_creditos"]?.ToString(), out var creditos) ? creditos : 0;
        campoHoraAcom = int.TryParse(reg["hora_acom"]?.ToString(), out var acom) ? acom : 0;
        campoHoraInd = int.TryParse(reg["hora_ind"]?.ToString(), out var hind) ? hind : 0;
        campoMetodologia = reg["metodologia"]?.ToString() ?? string.Empty;
        campoFechaInicio = reg["fecha_inicio"] is DateTime dtInicio ? dtInicio : DateTime.Today;
        campoFechaFin = reg["fecha_fin"] is DateTime dtFin ? dtFin : null;
        campoDuracionAnios = int.TryParse(reg["duracion_anios"]?.ToString(), out var anios) ? anios : 0;
        campoDuracionSemestres = int.TryParse(reg["duracion_semestres"]?.ToString(), out var sems) ? sems : 0;
        campoTipoTitulacion = reg["tipo_titulacion"]?.ToString() ?? string.Empty;
        campoPrograma = int.TryParse(reg["programa"]?.ToString(), out var prog) ? prog : 0;
        mostrarFormulario = true;
        mensaje = string.Empty;
        await CargarProgramas();
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["codigo"] = campoCodigo,
            ["cant_creditos"] = campoCantCreditos,
            ["hora_acom"] = campoHoraAcom,
            ["hora_ind"] = campoHoraInd,
            ["metodologia"] = campoMetodologia,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd"),
            ["duracion_anios"] = campoDuracionAnios,
            ["duracion_semestres"] = campoDuracionSemestres,
            ["tipo_titulacion"] = campoTipoTitulacion,
            ["programa"] = campoPrograma
        };

        if (editando)
        {
            var resultado = await Api.ActualizarAsync("registro_calificado", "codigo", campoCodigo, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("registro_calificado", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var codigo = reg["codigo"]?.ToString() ?? string.Empty;
        var resultado = await Api.EliminarAsync("registro_calificado", "codigo", codigo);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            await CargarRegistros();
        }
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }

    private string ObtenerNombrePrograma(string? id)
    {
        if (string.IsNullOrEmpty(id))
            return string.Empty;

        var prog = programas.FirstOrDefault(p => p["id"]?.ToString() == id);
        return prog?["nombre"]?.ToString() ?? id;
    }
}
