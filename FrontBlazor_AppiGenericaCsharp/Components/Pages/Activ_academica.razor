@page "/activ_academica"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Actividad Académica</PageTitle>

<div class="container mt-4">
    <h3>Actividad Académica</h3>
    <p class="lead">Administración de actividades académicas del módulo de Innovación Curricular.</p>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Actividad</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Actividad" : "Nueva Actividad")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">ID</label>
                        <input class="form-control" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Créditos</label>
                        <input type="number" class="form-control" @bind="campoNumCreditos" min="0" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" @bind="campoTipo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Área de formación</label>
                        <input class="form-control" @bind="campoAreaFormacion" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">H. Acom</label>
                        <input type="number" class="form-control" @bind="campoHAcom" min="0" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">H. Indep</label>
                        <input type="number" class="form-control" @bind="campoHIndep" min="0" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Idioma</label>
                        <input class="form-control" @bind="campoIdioma" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Espejo</label>
                        <select class="form-select" @bind="campoEspejo">
                            <option value="false">No</option>
                            <option value="true">Sí</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Entidad espejo</label>
                        <input class="form-control" @bind="campoEntidadEspejo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">País espejo</label>
                        <input class="form-control" @bind="campoPaisEspejo" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Programa</label>
                        <select class="form-select" @bind="campoDisenio">
                            <option value="0">Seleccione un programa</option>
                            @foreach (var prog in programas)
                            {
                                <option value="@Convert.ToInt32(prog["id"])">@prog["nombre"]</option>
                            }
                        </select>
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Cred</th>
                    <th>Tipo</th>
                    <th>Área formación</th>
                    <th>H. Acom</th>
                    <th>H. Ind</th>
                    <th>Idioma</th>
                    <th>Espejo</th>
                    <th>Programa</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["num_creditos"]</td>
                        <td>@reg["tipo"]</td>
                        <td>@reg["area_formacion"]</td>
                        <td>@reg["h_acom"]</td>
                        <td>@reg["h_indep"]</td>
                        <td>@reg["idioma"]</td>
                        <td>@(reg["espejo"]?.ToString() == "True" ? "Sí" : "No")</td>
                        <td>@ObtenerNombrePrograma(reg["disenio"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla activ_academica.</div>
    }
</div>

@code {
    // ───────── VARIABLES DE ESTADO ─────────
    // Lista de actividades académicas obtenidas desde la API
    private List<Dictionary<string, object?>> registros = new();
    // Lista de programas para relacionar la actividad con su diseño curricular
    private List<Dictionary<string, object?>> programas = new();
    // Controla si se muestra el spinner de carga
    private bool cargando = true;
    // Controla si se muestra el formulario de creación/edición
    private bool mostrarFormulario = false;
    // Indica si estamos editando un registro existente
    private bool editando = false;
    // Mensaje de alerta para el usuario
    private string mensaje = string.Empty;
    // Indica si la última operación fue exitosa
    private bool exito = false;

    // Campos del formulario
    private string campoId = string.Empty;
    private string campoNombre = string.Empty;
    private int campoNumCreditos = 0;
    private string campoTipo = string.Empty;
    private string campoAreaFormacion = string.Empty;
    private int campoHAcom = 0;
    private int campoHIndep = 0;
    private string campoIdioma = string.Empty;
    private bool campoEspejo = false;
    private string campoEntidadEspejo = string.Empty;
    private string campoPaisEspejo = string.Empty;
    private int campoDisenio = 0;

    // ───────── CICLO DE VIDA ─────────
    // Se ejecuta al inicializar el componente y carga los programas y registros
    protected override async Task OnInitializedAsync()
    {
        await CargarProgramas();
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("activ_academica");
        cargando = false;
    }

    private async Task CargarProgramas()
    {
        programas = await Api.ListarAsync("programa");
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoId = string.Empty;
        campoNombre = string.Empty;
        campoNumCreditos = 0;
        campoTipo = string.Empty;
        campoAreaFormacion = string.Empty;
        campoHAcom = 0;
        campoHIndep = 0;
        campoIdioma = string.Empty;
        campoEspejo = false;
        campoEntidadEspejo = string.Empty;
        campoPaisEspejo = string.Empty;
        campoDisenio = 0;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = reg["id"]?.ToString() ?? string.Empty;
        campoNombre = reg["nombre"]?.ToString() ?? string.Empty;
        campoNumCreditos = int.TryParse(reg["num_creditos"]?.ToString(), out var creditos) ? creditos : 0;
        campoTipo = reg["tipo"]?.ToString() ?? string.Empty;
        campoAreaFormacion = reg["area_formacion"]?.ToString() ?? string.Empty;
        campoHAcom = int.TryParse(reg["h_acom"]?.ToString(), out var acom) ? acom : 0;
        campoHIndep = int.TryParse(reg["h_indep"]?.ToString(), out var hind) ? hind : 0;
        campoIdioma = reg["idioma"]?.ToString() ?? string.Empty;
        campoEspejo = bool.TryParse(reg["espejo"]?.ToString(), out var espejo) ? espejo : false;
        campoEntidadEspejo = reg["entidad_espejo"]?.ToString() ?? string.Empty;
        campoPaisEspejo = reg["pais_espejo"]?.ToString() ?? string.Empty;
        campoDisenio = int.TryParse(reg["disenio"]?.ToString(), out var prog) ? prog : 0;
        mostrarFormulario = true;
        mensaje = string.Empty;
        await CargarProgramas();
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["nombre"] = campoNombre,
            ["num_creditos"] = campoNumCreditos,
            ["tipo"] = campoTipo,
            ["area_formacion"] = campoAreaFormacion,
            ["h_acom"] = campoHAcom,
            ["h_indep"] = campoHIndep,
            ["idioma"] = campoIdioma,
            ["espejo"] = campoEspejo,
            ["entidad_espejo"] = campoEntidadEspejo,
            ["pais_espejo"] = campoPaisEspejo,
            ["disenio"] = campoDisenio
        };

        if (editando)
        {
            datos.Remove("id");
            var resultado = await Api.ActualizarAsync("activ_academica", "id", campoId, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("activ_academica", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var id = reg["id"]?.ToString() ?? string.Empty;
        var resultado = await Api.EliminarAsync("activ_academica", "id", id);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
        {
            await CargarRegistros();
        }
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }

    private string ObtenerNombrePrograma(string? id)
    {
        if (string.IsNullOrEmpty(id))
            return string.Empty;

        var prog = programas.FirstOrDefault(p => p["id"]?.ToString() == id);
        return prog?["nombre"]?.ToString() ?? id;
    }
}
